{
  "mcpServers": {
    "chrome-devtools": {
      "command": "pnpx",
      "args": ["chrome-devtools-mcp@latest", "--autoConnect"]
    }
  },
  "browsermcp": {
    "autoApprove": [
      "browser_navigate",
      "browser_go_forward",
      "browser_click",
      "browser_hover",
      "browser_type",
      "browser_select_option",
      "browser_press_key",
      "browser_wait",
      "browser_get_console_logs",
      "browser_screenshot"
    ],
    "disabled": true,
    "timeout": 30,
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@browsermcp/mcp@latest"]
  }
}
