{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "default": {},
      "type": "object",
      "properties": {
        "第几天": {
          "default": 1,
          "type": "number"
        },
        "天气": {
          "default": "晴天",
          "type": "string",
          "enum": [
            "晴天",
            "多云",
            "小雨",
            "暴雨"
          ]
        },
        "今日结算说明": {
          "default": "新的一天尚未结算。",
          "type": "string"
        }
      }
    },
    "农场": {
      "default": {},
      "type": "object",
      "properties": {
        "资金": {
          "default": 100,
          "type": "number"
        },
        "地块": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "地块名"
          },
          "additionalProperties": {
            "default": {},
            "type": "object",
            "properties": {
              "状态": {
                "default": "空闲",
                "type": "string",
                "enum": [
                  "空闲",
                  "种植中",
                  "可收获"
                ]
              },
              "作物": {
                "default": "无",
                "type": "string"
              },
              "剩余生长天数": {
                "type": "number"
              },
              "负责员工": {
                "default": "无",
                "type": "string"
              }
            }
          }
        }
      }
    },
    "员工市场": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "劳动力名"
      },
      "additionalProperties": {
        "default": {},
        "type": "object",
        "properties": {
          "工种": {
            "default": "杂工",
            "type": "string",
            "enum": [
              "播种",
              "照料",
              "收获",
              "杂工"
            ]
          },
          "日薪": {
            "default": 10,
            "type": "number"
          },
          "体力": {
            "default": 100,
            "type": "number"
          }
        }
      }
    },
    "已雇员工": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "劳动力名"
      },
      "additionalProperties": {
        "default": {},
        "type": "object",
        "properties": {
          "工种": {
            "default": "杂工",
            "type": "string",
            "enum": [
              "播种",
              "照料",
              "收获",
              "杂工"
            ]
          },
          "日薪": {
            "default": 10,
            "type": "number"
          },
          "体力": {
            "default": 100,
            "type": "number"
          },
          "当前任务": {
            "default": "待命",
            "type": "string"
          }
        }
      }
    },
    "待处理提示": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "提示名"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}